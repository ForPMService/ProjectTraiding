.vs/
bin/
obj/
**/bin/
**/obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider
.idea/
*.sln.iml

# Node / Angular
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
**/pgdata/
**/clickhousedata/
**/miniodata/
.env
.env.local
.env.*
!.env.example
docker-compose.override.yml

# Secrets
secrets/
**/*.pem
**/*.key
**/*.crt

# OS files
Thumbs.db
.DS_Store

# Logs and temp
*.log
tmp/
temp/

# Local runtime storage
storage/
storage/raw/
storage/logs/
*.jsonl

# VS Code
.vscode/
